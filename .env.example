# GitHub Fingerprint — Environment Variables
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# === Required ===

# GitHub personal access token with public repo read access.
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN="ghp_your_token_here"

# === Optional (wallet) ===

# Privy application ID and secret for implicit embedded wallet creation.
# Get these from the Privy Dashboard: https://dashboard.privy.io
# When absent, wallet creation is gracefully disabled (attestation hashes
# are not stored in a data backpack).
PRIVY_APP_ID=""
PRIVY_APP_SECRET=""

# === Optional (attestation) ===

# Ed25519 signing key, base64-encoded. If absent, a key is auto-generated
# at startup and persisted to disk.
ATTEST_PRIVATE_KEY=""
